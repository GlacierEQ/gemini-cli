{
  "monitoring": {
    "enabled": true,
    "metrics": [
      "cpu",
      "memory",
      "response_time"
    ],
    "alerts": {
      "cpu_threshold": 80,
      "memory_threshold": 85,
      "response_time_threshold": 1000
    }
  },
  "optimization": {
    "caching": true,
    "compression": true,
    "minification": true,
    "lazy_loading": true
  }
}