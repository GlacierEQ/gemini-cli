{
  "version": "4.0.0",
  "optimization": {
    "level": "maximum",
    "compression": true,
    "tokenLimit": 4096,
    "caching": true
  },
  "providers": {
    "primary": {
      "name": "kilo-code",
      "endpoint": "SENSITIVE_REDACTED_ENDPOINT",
      "model": "kilo-v4",
      "maxTokens": 4096
    },
    "fallback": {
      "name": "openai",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4",
      "maxTokens": 4096
    }
  },
  "security": {
    "encryption": "AES-256",
    "keyRotation": "30d",
    "rateLimit": 1000
  }
}