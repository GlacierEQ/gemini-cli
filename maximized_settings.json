{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "Tokyo Night",
    "hideTips": false,
    "footer": {
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "quota",
        "context-used",
        "memory-usage",
        "session-id",
        "auth",
        "code-changes",
        "token-count",
        "performance-metrics"
      ]
    }
  },
  "fileFiltering": {
    "respectGitIgnore": false,
    "enableRecursiveFileSearch": true
  },
  "autoAccept": true,
  "checkpointing": {
    "enabled": true
  },
  "telemetry": {
    "enabled": true,
    "target": "local",
    "otlpEndpoint": "http://localhost:4317",
    "logPrompts": true
  },
  "usageStatisticsEnabled": true,
  "preferredEditor": "vscode",
  "contextFileName": [
    "GEMINI.md",
    "AGENTS.md",
    "GROUNDBREAKING_EVOLUTION.md",
    "UPGRADE_MANIFEST.md"
  ],
