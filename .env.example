# APEX MCP Server — Environment Configuration
# Copy to .env and fill in your values
# cp .env.example .env

# ─── Required ────────────────────────────────────────────────
# Notion integration token (from https://www.notion.so/my-integrations)
NOTION_API_KEY=secret_

# ─── Server Paths ────────────────────────────────────────────
REPO_ROOT=/path/to/apex-fs-commander

# ─── Notion DB IDs (pre-wired to APEX Notion Server Hub) ─────
NOTION_QUEUE_DB=66a2012916064ff5b0f54c252569a4b7
NOTION_LOG_DB=94a5c74bdd9f43268bffd19ded518d43
NOTION_TOOLS_DB=0abc5497d21b4d50b40d88414ad04218
NOTION_CONFIG_DB=a524373a1d3f457a8804aa3d215642b1

# ─── Tuning ──────────────────────────────────────────────────
EXEC_TIMEOUT=300
COMMAND_POLL_INTERVAL=5
MAX_CONCURRENT=3
LOG_LEVEL=INFO

# ─── External Services (optional) ────────────────────────────
# GITHUB_TOKEN=ghp_
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=eyJ...
